{
  "name": "saasblocks",
  "version": "1.0.0",
  "description": "Compact SaaS UI component library — ~200 components, 5 themes, and a gallery viewer for building dashboards fast.",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
